#include <SPI.h>
#include <RF24.h>
#include "sbus.h"

// ================= SBUS =================
bfs::SbusRx sbus_rx(&Serial2, 16, 17, true);
bfs::SbusData sbusData;

// ================= NRF MODULES =================
RF24 radio1(4, 5);    // CE, CSN
RF24 radio2(15, 2);   // CE, CSN

const byte address[6] = "DRONE";

// ================= PAYLOAD =================
struct __attribute__((__packed__)) Payload {
  uint16_t ch[4];
  bool failsafe;
  uint8_t seq;
};

Payload packet;
uint8_t sequence = 0;

void setup() {

  Serial.begin(115200);
  sbus_rx.Begin();

  // ---------- RADIO 1 ----------
  if (!radio1.begin()) {
    Serial.println("NRF1 failed!");
    while(1);
  }

  radio1.setChannel(70);
  radio1.setDataRate(RF24_250KBPS);
  radio1.setPALevel(RF24_PA_LOW);
  radio1.setAutoAck(false);
  radio1.openWritingPipe(address);
  radio1.stopListening();

  // ---------- RADIO 2 ----------
  if (!radio2.begin()) {
    Serial.println("NRF2 failed!");
    while(1);
  }

  radio2.setChannel(90);
  radio2.setDataRate(RF24_250KBPS);
  radio2.setPALevel(RF24_PA_LOW);
  radio2.setAutoAck(false);
  radio2.openWritingPipe(address);
  radio2.stopListening();

  Serial.println("Dual NRF TX Ready");
}

void loop() {

  if (sbus_rx.Read()) {

    sbusData = sbus_rx.data();

    for (int i = 0; i < 4; i++) {
      packet.ch[i] = sbusData.ch[i];
    }

    packet.failsafe = sbusData.failsafe;
    packet.seq = sequence++;

    // Send through both radios
    bool ok1 = radio1.write(&packet, sizeof(packet));
    bool ok2 = radio2.write(&packet, sizeof(packet));

    Serial.print("CH: ");
    Serial.print(packet.ch[0]); Serial.print(" ");
    Serial.print(packet.ch[1]); Serial.print(" ");
    Serial.print(packet.ch[2]); Serial.print(" ");
    Serial.print(packet.ch[3]);

    Serial.print(" | TX1:");
    Serial.print(ok1 ? "OK" : "FAIL");

    Serial.print(" | TX2:");
    Serial.println(ok2 ? "OK" : "FAIL");
  }
}


